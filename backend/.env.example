# D'Tee & Gee Kitchen - Environment Variables
# Copy this file to .env and fill in your values

# Flask Configuration
SECRET_KEY=your-secret-key-here-change-in-production
FLASK_ENV=development
FLASK_DEBUG=False

# Production Domain (Required for CORS in production)
# Set this to your actual domain when deploying
PRODUCTION_DOMAIN=https://your-production-domain.com

# Database Configuration
# For local development (SQLite) - comment out or leave empty to use SQLite
# DATABASE_URL=sqlite:///database/app.db

# For production (PostgreSQL) - uncomment and fill in your details
# DATABASE_URL=postgresql://username:password@host:5432/database_name
#
# Example connection strings:
# - Render: postgresql://user:password@dpg-xxxxx.oregon-postgres.render.com/dbname
# - Railway: postgresql://postgres:password@containers-us-west-xxx.railway.app:5432/railway
# - Supabase: postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres
# - Neon: postgresql://user:password@ep-xxxxx.us-east-2.aws.neon.tech/neondb
# - Local: postgresql://postgres:password@localhost:5432/dteeandgee

# Email Configuration (for order notifications)
# Use Gmail App Password (not your regular password)
# See: https://support.google.com/accounts/answer/185833
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@yourdomain.com

# Monnify Configuration (Payment Gateway)
# Get your keys from: https://app.monnify.com/developer
# For testing, use sandbox: https://sandbox.monnify.com
# For production, use: https://api.monnify.com
MONNIFY_API_KEY=your_monnify_api_key_here
MONNIFY_SECRET_KEY=your_monnify_secret_key_here
MONNIFY_CONTRACT_CODE=your_monnify_contract_code_here
MONNIFY_BASE_URL=https://sandbox.monnify.com
